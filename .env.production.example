# ===== REQUIRED =====

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/whatsenvia

# Redis connection string
REDIS_URL=redis://default:password@host:6379

# JWT secret - USE A STRONG RANDOM STRING (min 64 chars recommended)
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET

# Allowed origins for CORS (comma-separated)
# Set this to your frontend URL in production
ALLOWED_ORIGINS=https://yourdomain.com

# ===== OPTIONAL =====

NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# JWT expiration (default: 7d)
JWT_EXPIRES_IN=7d

# API rate limit per minute (default: 100)
API_RATE_LIMIT=100

# WhatsApp settings
WHATSAPP_SESSION_PATH=./sessions
WHATSAPP_MAX_RETRIES=3
WHATSAPP_MESSAGE_DELAY_MS=2000

# WhatsApp message rate limits (anti-ban)
RATE_LIMIT_MAX_PER_MINUTE=8
RATE_LIMIT_MAX_PER_HOUR=200
RATE_LIMIT_MAX_PER_DAY=1500

# Meta Cloud API (optional - for official WhatsApp API)
# META_ACCESS_TOKEN=
# META_PHONE_NUMBER_ID=
# META_BUSINESS_ACCOUNT_ID=
# META_WEBHOOK_VERIFY_TOKEN=

# Admin seed credentials
ADMIN_EMAIL=admin@whatsenvia.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADMIN_NAME=Administrador

# Frontend API URL (set in frontend environment)
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
