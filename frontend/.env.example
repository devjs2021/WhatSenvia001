# URL base de la API del backend (sin barra final)
NEXT_PUBLIC_API_URL=http://localhost:3001

# URL del WebSocket del backend (chat en vivo, monitor de campañas)
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Google OAuth (login social) — debe coincidir con GOOGLE_CLIENT_ID del backend
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Meta App ID (flujo de conexión Embedded Signup de WhatsApp Cloud API)
NEXT_PUBLIC_META_APP_ID=

# Web Push (VAPID) — debe coincidir con VAPID_PUBLIC_KEY del backend
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
